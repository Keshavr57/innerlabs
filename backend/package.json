{
  "name": "prompt-tracking-backend",
  "version": "1.0.0",
  "description": "Node.js backend API for the Prompt Tracking System - orchestrates AI prompt processing, retry logic, and persistent storage",
  "main": "src/server.js",
  "type": "commonjs",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "test:properties": "jest --testNamePattern='Property' --verbose",
    "test:unit": "jest --testPathPattern='unit' --verbose",
    "test:integration": "jest --testPathPattern='integration' --verbose"
  },
  "keywords": [
    "prompt-tracking",
    "ai-service",
    "llm",
    "groq",
    "mongodb",
    "express",
    "retry-logic"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.6.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "mongoose": "^8.0.3"
  },
  "devDependencies": {
    "fast-check": "^3.15.0",
    "jest": "^29.7.0",
    "mongodb-memory-server": "^11.0.1",
    "nodemon": "^3.0.2",
    "supertest": "^6.3.3"
  },
  "jest": {
    "testEnvironment": "node",
    "coverageDirectory": "coverage",
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/server.js"
    ],
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "coverageThreshold": {
      "global": {
        "lines": 80,
        "branches": 75,
        "functions": 80,
        "statements": 80
      }
    }
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
